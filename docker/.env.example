# Bot token from https://fluxer.app/developers
BOT_TOKEN=your_bot_token_here

# MySQL credentials
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=remix
MYSQL_USER=remix
MYSQL_PASSWORD=change_me

# Web dashboard port mapping (host:container)
WEB_PORT=8080

# NodeLink port mapping
NODELINK_PORT=3000

# Timezone
TZ=UTC

# Optional: paste your entire config.json as a single line (base64 or raw JSON)
# If set, the entrypoint will write it to /app/config.json on first boot.
# CONFIG_JSON={"token":"...","mysql":{...}}

# Fluxer OAuth2 (for dashboard)
FLUXER_OAUTH_ID=
FLUXER_OAUTH_SECRET=
FLUXER_OAUTH_REDIRECT_URI=
